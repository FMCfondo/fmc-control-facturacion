# Variables de entorno — copiar a .env.local (NO subir a GitHub).
# Valores en: Supabase → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Service role: SOLO servidor. Nunca exponer en el navegador ni en GitHub.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Envío de correos por Gmail (SOLO servidor). Crear "Contraseña de aplicación" en Google.
GMAIL_USER=facturacion@fondomutuodecobertura.com
GMAIL_APP_PASSWORD=la-contrasena-de-aplicacion-de-16-caracteres
